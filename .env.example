# ═════════════════════════════════════════════════════════════════════
# Callman on-prem — configuration.
#
# 1. Copy this file:        cp .env.example .env
# 2. Fill in every value marked <CHANGE_ME>.
# 3. Generate each secret:  openssl rand -hex 32
#
# Never commit your real `.env`. This template contains placeholders only.
# Full reference: docs/ENVIRONMENT.md
# ═════════════════════════════════════════════════════════════════════

# ─── Version ─────────────────────────────────────────────────────────
# Which release to run. We tell you the version to use, e.g. 1.0.1.
CALLMAN_VERSION=<CHANGE_ME_VERSION>

# Edition marker — keep as "onprem".
CALLMAN_EDITION=onprem

# Runtime mode — keep as "production".
NODE_ENV=production

# ─── Network ─────────────────────────────────────────────────────────
# The single port the API listens on AND is published on. Browse / curl
# the backend at http://<this-host>:<CALLMAN_PORT>.
CALLMAN_PORT=8080

# ─── MongoDB (bundled) ───────────────────────────────────────────────
# Credentials for the bundled MongoDB container. Pick your own — the app's
# connection string is built from these automatically.
MONGO_ROOT_USERNAME=callman
MONGO_ROOT_PASSWORD=<CHANGE_ME_MONGO_PASSWORD>

# ─── Redis (bundled) ─────────────────────────────────────────────────
# Password for the bundled Redis container (also used by the app).
REDIS_PASSWORD=<CHANGE_ME_REDIS_PASSWORD>

# ─── JWT / auth secrets (REQUIRED, must be DIFFERENT from each other) ─
# Each ≥ 32 chars. Generate four DISTINCT values:  openssl rand -hex 32
JWT_SECRET=<CHANGE_ME_RUN_openssl_rand_hex_32>
JWT_REFRESH_SECRET=<CHANGE_ME_RUN_openssl_rand_hex_32>

# Token lifetimes (optional — sensible defaults shown).
# JWT_EXPIRES_IN=1h
# JWT_REFRESH_EXPIRES_IN=30d

# ─── Encryption secrets (REQUIRED, must be DIFFERENT) ────────────────
# Encrypt stored sessions + saved DB/connection credentials. ≥ 32 chars.
SESSION_TOKEN_ENCRYPTION_SECRET=<CHANGE_ME_RUN_openssl_rand_hex_32>
CONNECTION_ENCRYPTION_KEY=<CHANGE_ME_RUN_openssl_rand_hex_32>

# All four secrets above MUST be four DIFFERENT values, or the app refuses
# to start.

# ─── Worker / BullMQ (optional) ──────────────────────────────────────
# Background scenario-run engine. Defaults are fine for most installs.
# BULLMQ_WORKER_CONCURRENCY=50
# PM2_INSTANCES=1

# ─── Bull Board queue dashboard (optional) ───────────────────────────
# Set BOTH to enable the /admin/queues dashboard (off when unset).
# BULL_BOARD_USERNAME=<CHANGE_ME>
# BULL_BOARD_PASSWORD=<CHANGE_ME>

# ─── Observability (optional) ────────────────────────────────────────
# Prometheus /metrics endpoint. Leave on; set false to disable.
# METRICS_ENABLED=true

# Error reporter → Telegram. This forwards desktop crash reports to a
# Telegram channel run by the vendor. On-prem installs normally DISABLE it
# (no outbound internet needed). To DISABLE, leave the value EMPTY as below
# (an empty value = off). To ENABLE, set it to a value AND provide both
# TELEGRAM_BOT_TOKEN and TELEGRAM_CHAT_ID.
TELEGRAM_ENABLED=

# ─── CORS (optional) ─────────────────────────────────────────────────
# Comma-separated browser origins allowed to call the API. Leave blank for
# desktop-app-only installs.
# CLIENT_ORIGIN=

# Public URLs (optional) — set to your real external URL if you expose the
# API publicly, so generated links/mock URLs are correct.
# PUBLIC_API_BASE_URL=https://callman.example.com
# MOCK_PUBLIC_BASE_URL=https://callman.example.com

# ─── Migration backup (optional) ─────────────────────────────────────
# Where the automatic pre-migration mongodump is written (a Docker volume
# is mounted here by default — leave as-is).
# MONGODB_BACKUP_DIR=/backups

# ─── Admin panel (FUTURE — not available yet) ────────────────────────
# The admin panel image isn't published yet. When it ships you'll set:
# CALLMAN_ADMIN_PORT=8081
# (CALLMAN_API_URL is wired automatically by docker-compose.yml.)

# ═════════════════════════════════════════════════════════════════════
# Using your OWN MongoDB / Redis instead of the bundled ones?
# See docs/ENVIRONMENT.md → "Using your own MongoDB / Redis". In short:
# uncomment + set these, and disable the bundled services.
# MONGODB_URI=mongodb://user:pass@your-mongo-host:27017/callman?authSource=admin
# REDIS_URL=redis://:pass@your-redis-host:6379
# ═════════════════════════════════════════════════════════════════════
